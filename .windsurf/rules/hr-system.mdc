## 3. Data Fetching Rules

### 3.1 Service Layer

Every feature has its own service file. No API calls inside components.

```
src/features/{module}/services/{module}.service.ts
```

```typescript
// CORRECT — all API logic in service
export const employeeService = {
  getAll: (params: EmployeeListParams) =>
    apiClient.get<PaginatedResponse<Employee>>('/hr/employees', { params }).then(r => r.data),

  getById: (id: string) =>
    apiClient.get<ApiResponse<Employee>>(`/hr/employees/${id}`).then(r => r.data),

  create: (body: CreateEmployeeDto) =>
    apiClient.post<ApiResponse<Employee>>('/hr/employees', body).then(r => r.data),

  update: (id: string, body: UpdateEmployeeDto) =>
    apiClient.patch<ApiResponse<Employee>>(`/hr/employees/${id}`, body).then(r => r.data),

  remove: (id: string) =>
    apiClient.delete<ApiResponse<void>>(`/hr/employees/${id}`).then(r => r.data),
};
```

### 3.2 Query Keys

```typescript
['employees', { companyId, page, limit }]     // list
['employees', id]                              // single
['branches', { companyId, page, limit }]
['departments', { companyId, branchId }]
['roles', { page, limit }]
['roles', roleId, 'permissions']              // nested
['employee-assignments', employeeId]
['user-roles', userId]
['auth', 'access-profile']                   // permissions — fetched once
```

### 3.3 useQuery Pattern

```typescript
const { data, isLoading, isError } = useQuery({
  queryKey: ['employees', { companyId, page, limit }],
  queryFn: () => employeeService.getAll({ companyId, page, limit }),
  staleTime: 2 * 60 * 1000,
});

const items = data?.data?.items ?? [];
const pagination = data?.data?.pagination;
```

**staleTime by data type:**
- Reference / lookup data (companies, branches, job-titles, leave-types): `5 * 60 * 1000`
- Active records (employees, users, roles): `2 * 60 * 1000`
- Frequently changing (audit-logs): `30 * 1000`

### 3.4 useMutation Pattern

```typescript
const create = useMutation({
  mutationFn: employeeService.create,
  onSuccess: () => {
    queryClient.invalidateQueries({ queryKey: ['employees'] });
    toast.success('تم الحفظ بنجاح');
  },
  onError: (error: ApiErrorResponse) => {
    const details = error.error?.details;
    const msg = Array.isArray(details) ? details.join('، ') : (details ?? error.message);
    toast.error(msg);
  },
});
```

### 3.5 Forbidden Fetching Patterns

```typescript
// NEVER — useEffect for data fetching
useEffect(() => { fetch('/api/employees').then(...) }, []);

// NEVER — fetch() inside components
const res = await fetch('/hr/employees');

// NEVER — manual loading state
const [loading, setLoading] = useState(false);

// NEVER — accessing data without optional chaining
const items = data.data.items; // will throw if data is undefined
```

