# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Public (embedded in the client bundle at build time)
NEXT_PUBLIC_API_URL=/api-backend
NEXT_PUBLIC_HERE_API_KEY=your_here_maps_api_key_here

# Server-side API proxy target (used in next.config rewrites at build time)
BACKEND_URL=http://localhost:3000

# Docker Compose host port mapping
# FRONTEND_PORT=3001

# Dev only — optional login form pre-fill (npm run dev). Never set in production.
# NEXT_PUBLIC_DEV_LOGIN_EMAIL=
# NEXT_PUBLIC_DEV_LOGIN_PASSWORD=

# Dev only — ignored in production Docker image
# ALLOWED_DEV_ORIGINS=192.168.1.x
